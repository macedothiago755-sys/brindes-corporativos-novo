DATABASE_URL="postgresql://user:password@localhost:5432/brindes_corporativos?schema=public"
# Conexão direta (sem pooler) usada por migrações. No Neon, use o mesmo host
# do DATABASE_URL porém SEM o sufixo "-pooler". Evita o erro P1002 (advisory lock).
DIRECT_URL="postgresql://user:password@localhost:5432/brindes_corporativos?schema=public"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Integrações (estrutura preparada, preencher quando disponível)
RESEND_API_KEY=""
NOTIFY_EMAIL_TO="comercial@suaempresa.com.br"
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GTM_ID=""

UPLOAD_DIR="./public/uploads"
