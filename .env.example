DATABASE_URL="postgresql://user:password@localhost:5432/brindes_corporativos?schema=public"
# Conexão direta (sem pooler) usada por migrações. No Neon, use o mesmo host
# do DATABASE_URL porém SEM o sufixo "-pooler". Evita o erro P1002 (advisory lock).
DIRECT_URL="postgresql://user:password@localhost:5432/brindes_corporativos?schema=public"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Notificação de novo orçamento ao comercial (ambos opcionais).
# E-mail via Resend: defina a chave + destinatário(s) separados por vírgula.
# NOTIFY_EMAIL_FROM precisa ser de um domínio verificado no Resend; sem ele,
# usa o remetente de teste onboarding@resend.dev (só entrega ao dono da conta).
RESEND_API_KEY=""
NOTIFY_EMAIL_TO="comercial@suaempresa.com.br"
NOTIFY_EMAIL_FROM="Paint Colors <comercial@paintcolorscompany.com>"
# Webhook genérico (Slack / Discord / n8n / Zapier): cola a URL de incoming webhook.
LEAD_NOTIFICATION_WEBHOOK_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GTM_ID=""

UPLOAD_DIR="./public/uploads"

# --- Sentry (monitoramento de erros) ---
# DSN do projeto Sentry. Defina NEXT_PUBLIC_SENTRY_DSN para capturar erros no
# navegador também. Sem DSN, a integração vira no-op (não envia nada).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Necessários apenas para upload de source maps no build de produção (Vercel).
# Sem eles, o build funciona normalmente, apenas sem stack traces legíveis.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
