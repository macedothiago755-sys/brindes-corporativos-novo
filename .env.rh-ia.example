# Variáveis usadas pelo docker-compose.yml do módulo RH IA.
# Copie para `.env` na raiz (não commitado) e preencha com valores reais
# apenas no seu ambiente local/CI — nunca aqui.

POSTGRES_USER=rh_ia
POSTGRES_PASSWORD=
POSTGRES_DB=rh_ia

JWT_SECRET=
ANTHROPIC_API_KEY=

# Integrações Omnichannel (Slack / WhatsApp Business)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v21.0

NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
