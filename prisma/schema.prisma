generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERADOR
  VISUALIZADOR
}

enum ProductStatus {
  ATIVO
  RASCUNHO
  INDISPONIVEL
}

enum QuoteStatus {
  NOVO
  EM_ANALISE
  RESPONDIDO
  FECHADO
  PERDIDO
}

enum CustomizationMethod {
  GRAVACAO_LASER
  SILK_SCREEN
  BORDADO
  IMPRESSAO_UV
  TRANSFER
}

enum ImportJobStatus {
  PENDENTE
  EM_EXECUCAO
  CONCLUIDO
  CONCLUIDO_COM_ERROS
  FALHOU
}

enum ImportedProductStatus {
  IMPORTADO
  ERRO
  PROMOVIDO
  IGNORADO
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  role       Role        @default(ADMIN)
  createdAt  DateTime    @default(now())
  importJobs ImportJob[]
}

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")
  products Product[]
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String
  tags        String[]
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  sku                  String?               @unique
  supplierCode         String?
  brand                String?
  status               ProductStatus         @default(RASCUNHO)
  description          String
  shortDescription     String?
  benefits             String[]
  features             String[]
  materials            String[]
  colors               String[]
  tags                 String[]              @default([])
  idealFor             String[]
  customizationMethods CustomizationMethod[]
  images               String[]
  price                Float?
  promoPrice           Float?
  saleUnit             String?               @default("unidade")
  minQty               Int                   @default(50)
  leadTimeDays         Int                   @default(15)
  shippingDays         Int?
  dimensions           String?
  printArea            String?
  metaTitle            String?
  metaDescription      String?
  sustainable          Boolean               @default(false)
  premium              Boolean               @default(false)
  featured             Boolean               @default(false)
  categoryId           String
  category             Category              @relation(fields: [categoryId], references: [id])
  attributes           ProductAttribute[]
  quoteItems           QuoteItem[]
  views                ProductView[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([status])
  @@index([categoryId])
}

model ProductAttribute {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductView {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model Quote {
  id          String       @id @default(cuid())
  clienteNome String
  empresa     String
  email       String
  telefone    String
  cidade      String?
  observacoes String?
  objetivo    String?
  prazo       String?
  status      QuoteStatus  @default(NOVO)
  items       QuoteItem[]
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model QuoteItem {
  id             String                @id @default(cuid())
  quoteId        String
  quote          Quote                 @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId      String
  product        Product               @relation(fields: [productId], references: [id])
  quantidade     Int
  cores          String[]
  personalizacao String[]
  metodo         CustomizationMethod[]
  createdAt      DateTime              @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  createdAt DateTime @default(now())
}

model Supplier {
  id         String      @id @default(cuid())
  name       String
  baseUrl    String
  adapterKey String
  importJobs ImportJob[]
  createdAt  DateTime    @default(now())
}

model ImportJob {
  id               String            @id @default(cuid())
  supplierId       String
  supplier         Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  categoryUrl      String
  status           ImportJobStatus   @default(PENDENTE)
  productsFound    Int               @default(0)
  productsImported Int               @default(0)
  productsFailed   Int               @default(0)
  startedAt        DateTime?
  finishedAt       DateTime?
  requestedById    String?
  requestedBy      User?             @relation(fields: [requestedById], references: [id])
  products         ImportedProduct[]
  errors           ImportError[]
  createdAt        DateTime          @default(now())

  @@index([requestedById])
}

model ImportedProduct {
  id                String                @id @default(cuid())
  importJobId       String
  importJob         ImportJob             @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  sourceUrl         String
  nome              String
  codigo            String?
  sku               String?
  categoria         String?
  marca             String?
  descricaoCurta    String?
  descricaoLonga    String?
  descricaoIA       String?
  preco             Float?
  dadosTecnicos     Json                  @default("{}")
  imagemPrincipal   String?
  imagens           Json                  @default("[]")
  status            ImportedProductStatus @default(IMPORTADO)
  promotedProductId String?
  createdAt         DateTime              @default(now())

  @@index([codigo])
}

model ImportError {
  id          String    @id @default(cuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  sourceUrl   String?
  produto     String?
  motivo      String
  createdAt   DateTime  @default(now())
}
