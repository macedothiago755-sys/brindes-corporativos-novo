PORT=3001
NODE_ENV=development

DATABASE_URL="postgresql://user:password@localhost:5432/rh_ia?schema=public"

ANTHROPIC_API_KEY=""

JWT_SECRET="change-me"

# --- Integrações Omnichannel (Base de Conhecimento via Slack/WhatsApp) ---

# Slack (Event Subscriptions + Web API)
# Signing Secret do app Slack — valida a assinatura das requisições recebidas.
SLACK_SIGNING_SECRET=""
# Bot token (xoxb-...) usado para postar respostas via chat.postMessage.
SLACK_BOT_TOKEN=""

# WhatsApp Business (Meta Cloud API)
# Token arbitrário definido por você e ecoado na verificação do webhook (GET).
WHATSAPP_VERIFY_TOKEN=""
# App Secret do app Meta — valida a X-Hub-Signature-256 das mensagens.
WHATSAPP_APP_SECRET=""
# Token de acesso para chamar a Graph API e enviar respostas.
WHATSAPP_ACCESS_TOKEN=""
# ID do número remetente cadastrado no WhatsApp Business.
WHATSAPP_PHONE_NUMBER_ID=""
# Versão da Graph API (opcional; padrão v21.0).
WHATSAPP_GRAPH_VERSION="v21.0"
